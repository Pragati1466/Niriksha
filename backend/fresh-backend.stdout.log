prisma:query SELECT "public"."User"."id", "public"."User"."departmentId" FROM "public"."User" WHERE ("public"."User"."id" = $1 AND 1=1) LIMIT $2 OFFSET $3
prisma:query SELECT "public"."Inspection"."id", "public"."Inspection"."siteId", "public"."Inspection"."inspectorId", "public"."Inspection"."templateId", "public"."Inspection"."status", "public"."Inspection"."scheduledDate", "public"."Inspection"."completedDate", "public"."Inspection"."notes", "public"."Inspection"."confidenceScore", "public"."Inspection"."aiAnalysis", "public"."Inspection"."submissionOverrideReason", "public"."Inspection"."submissionOverriddenAt", "public"."Inspection"."createdAt", "public"."Inspection"."updatedAt" FROM "public"."Inspection" LEFT JOIN "public"."Site" AS "j1" ON ("j1"."id") = ("public"."Inspection"."siteId") WHERE ("public"."Inspection"."id" = $1 AND ("j1"."departmentId" = $2 AND ("j1"."id" IS NOT NULL))) LIMIT $3 OFFSET $4
prisma:query SELECT "public"."InspectionImage"."id", "public"."InspectionImage"."inspectionId", "public"."InspectionImage"."imageUrl", "public"."InspectionImage"."description", "public"."InspectionImage"."uploadedAt" FROM "public"."InspectionImage" WHERE "public"."InspectionImage"."inspectionId" IN ($1) OFFSET $2
prisma:query SELECT "public"."InspectionChecklist"."id", "public"."InspectionChecklist"."inspectionId", "public"."InspectionChecklist"."itemId", "public"."InspectionChecklist"."itemLabel", "public"."InspectionChecklist"."status", "public"."InspectionChecklist"."notes", "public"."InspectionChecklist"."evidence", "public"."InspectionChecklist"."createdAt", "public"."InspectionChecklist"."updatedAt" FROM "public"."InspectionChecklist" WHERE "public"."InspectionChecklist"."inspectionId" IN ($1) OFFSET $2
prisma:query SELECT "public"."VerificationFinding"."id", "public"."VerificationFinding"."inspectionId", "public"."VerificationFinding"."checklistItemId", "public"."VerificationFinding"."checklistLabel", "public"."VerificationFinding"."finding", "public"."VerificationFinding"."confidence", "public"."VerificationFinding"."evidenceReference", "public"."VerificationFinding"."createdAt" FROM "public"."VerificationFinding" WHERE "public"."VerificationFinding"."inspectionId" IN ($1) OFFSET $2
prisma:query SELECT "public"."ReviewAction"."id", "public"."ReviewAction"."inspectionId", "public"."ReviewAction"."reviewerId", "public"."ReviewAction"."action", "public"."ReviewAction"."oldStatus", "public"."ReviewAction"."newStatus", "public"."ReviewAction"."comments", "public"."ReviewAction"."createdAt" FROM "public"."ReviewAction" WHERE "public"."ReviewAction"."inspectionId" IN ($1) OFFSET $2
prisma:query SELECT "public"."ComplianceMemoryEvent"."id", "public"."ComplianceMemoryEvent"."inspectionId", "public"."ComplianceMemoryEvent"."siteId", "public"."ComplianceMemoryEvent"."checklistItemId", "public"."ComplianceMemoryEvent"."checklistLabel", "public"."ComplianceMemoryEvent"."eventType", "public"."ComplianceMemoryEvent"."outcome", "public"."ComplianceMemoryEvent"."finding", "public"."ComplianceMemoryEvent"."confidence", "public"."ComplianceMemoryEvent"."evidenceReference", "public"."ComplianceMemoryEvent"."actorId", "public"."ComplianceMemoryEvent"."reason", "public"."ComplianceMemoryEvent"."sourceRecordId", "public"."ComplianceMemoryEvent"."metadata", "public"."ComplianceMemoryEvent"."occurredAt" FROM "public"."ComplianceMemoryEvent" WHERE "public"."ComplianceMemoryEvent"."inspectionId" IN ($1) OFFSET $2
prisma:query SELECT "public"."AuditLog"."id", "public"."AuditLog"."userId", "public"."AuditLog"."action", "public"."AuditLog"."entityType", "public"."AuditLog"."entityId", "public"."AuditLog"."changes", "public"."AuditLog"."createdAt" FROM "public"."AuditLog" WHERE ("public"."AuditLog"."entityType" = $1 AND "public"."AuditLog"."entityId" = $2) ORDER BY "public"."AuditLog"."createdAt" ASC OFFSET $3
prisma:query SELECT "public"."Notification"."id", "public"."Notification"."userId", "public"."Notification"."type", "public"."Notification"."title", "public"."Notification"."message", "public"."Notification"."actionUrl", "public"."Notification"."read", "public"."Notification"."metadata", "public"."Notification"."createdAt" FROM "public"."Notification" WHERE "public"."Notification"."actionUrl" = $1 ORDER BY "public"."Notification"."createdAt" ASC OFFSET $2
