# NIRIKSHA Inspection Workflow API - Environment Variables
# Copy this file to .env and fill in the actual values

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/niriksha
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ============================================================================
# Redis Configuration (for Celery and caching)
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ============================================================================
# Application Configuration
# ============================================================================
APP_NAME=NIRIKSHA Inspection Workflow API
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# ============================================================================
# Server Configuration
# ============================================================================
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
JSON_LOGS=True

# ============================================================================
# AWS S3 Configuration (for file storage)
# ============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=niriksha-evidence
AWS_S3_PREFIX=evidence/

# ============================================================================
# CORS Configuration
# ============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# ============================================================================
# Authentication Configuration
# ============================================================================
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# ============================================================================
# Rate Limiting Configuration
# ============================================================================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=100

# ============================================================================
# Offline Sync Configuration
# ============================================================================
SYNC_MAX_RETRIES=3
SYNC_RETRY_DELAY_SECONDS=5
SYNC_CONFLICT_RESOLUTION=manual

# ============================================================================
# File Upload Configuration
# ============================================================================
MAX_FILE_SIZE_MB=100
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_DOCUMENT_TYPES=application/pdf

# ============================================================================
# AI Verification Configuration
# ============================================================================
AI_VERIFICATION_ENABLED=True
AI_VERIFICATION_CONFIDENCE_THRESHOLD=0.8

# ============================================================================
# Monitoring Configuration
# ============================================================================
SENTRY_DSN=
METRICS_ENABLED=False
