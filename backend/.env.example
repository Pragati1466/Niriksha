# Database
DATABASE_URL="file:./dev.db"

# Server
PORT=3001

# JWT Secret
JWT_SECRET="niriksha-dev-jwt-secret-change-in-production"
JWT_EXPIRES_IN="24h"

# IBM WatsonX Configuration
WATSONX_API_KEY="your-ibm-cloud-api-key"
WATSONX_PROJECT_ID="your-watsonx-project-id"
WATSONX_SPACE_ID="your-watsonx-space-id"
WATSONX_REGION="us-south"
WATSONX_MODEL_ID="ibm/granite-13b-chat-v2"
WATSONX_DEPLOYMENT_URL=""
WATSONX_VERSION="2023-09-01"

# Google Gemini API Key (fallback when WatsonX is not configured)
GEMINI_API_KEY=""

# AWS S3 (for image uploads, optional for dev)
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"

# AI Service Provider (watsonx | gemini | auto)
AI_PROVIDER="auto"

# CORS
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"