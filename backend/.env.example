# Database
DATABASE_URL="postgresql://user:password@localhost:5432/niriksha"

# JWT Secret
JWT_SECRET="your-jwt-secret-key"

# AWS S3 Configuration (for cloud storage)
# Leave AWS_S3_BUCKET empty to use local disk storage
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_S3_BUCKET="niriksha-inspections"

# API Configuration
PORT=3001
NODE_ENV=development

# AI Configuration
# Choose one: GEMINI_API_KEY for Google Gemini, GROQ_API_KEY for Groq, or OPENROUTER_API_KEY for OpenRouter
GEMINI_API_KEY="your-gemini-api-key"
GROQ_API_KEY="your-groq-api-key"
OPENROUTER_API_KEY="your-openrouter-api-key"

# Security Configuration
# Comma-separated list of allowed origins for CORS (e.g., "https://example.com,https://app.example.com")
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"
