generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(uuid())
  email                  String                  @unique
  password               String
  name                   String
  role                   String                  @default("INSPECTOR")
  departmentId           String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  auditLogs              AuditLog[]
  complianceMemoryEvents ComplianceMemoryEvent[]
  assignedInspections    Inspection[]            @relation("AssignedInspector")
  reviews                Review[]
  reviewActions          ReviewAction[]
  trustHistory           TrustHistory[]
  trustScore             TrustScore?
  department             Department?             @relation(fields: [departmentId], references: [id])

  @@index([email])
  @@index([role])
  @@index([departmentId])
  @@index([role, departmentId])
}

model Department {
  id          String               @id @default(uuid())
  name        String               @unique
  description String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  templates   InspectionTemplate[]
  sites       Site[]
  users       User[]

  @@index([name])
}

model Site {
  id                     String                  @id @default(uuid())
  name                   String
  address                String
  departmentId           String
  latitude               Float?
  longitude              Float?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  complianceMemoryEvents ComplianceMemoryEvent[]
  inspections            Inspection[]
  department             Department              @relation(fields: [departmentId], references: [id])

  @@index([departmentId])
}

model InspectionTemplate {
  id             String       @id @default(uuid())
  name           String
  description    String?
  departmentId   String
  checklistItems String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  inspections    Inspection[]
  department     Department   @relation(fields: [departmentId], references: [id])

  @@index([departmentId])
}

model Inspection {
  id                       String                  @id @default(uuid())
  siteId                   String
  inspectorId              String
  templateId               String
  status                   String                  @default("ASSIGNED")
  scheduledDate            DateTime
  completedDate            DateTime?
  notes                    String?
  confidenceScore          Float?
  aiAnalysis               String?
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  submissionOverrideReason String?
  submissionOverriddenAt   DateTime?
  complianceMemoryEvents   ComplianceMemoryEvent[]
  inspector                User                    @relation("AssignedInspector", fields: [inspectorId], references: [id])
  site                     Site                    @relation(fields: [siteId], references: [id])
  template                 InspectionTemplate      @relation(fields: [templateId], references: [id])
  checklists               InspectionChecklist[]
  images                   InspectionImage[]
  ordiAssessments          OrdiAssessment[]
  reports                  Report?
  reportVersions           ReportVersion[]
  reviews                  Review[]
  reviewActions            ReviewAction[]
  verificationFindings     VerificationFinding[]
  violations               Violation[]

  @@index([inspectorId])
  @@index([siteId])
  @@index([templateId])
  @@index([status])
  @@index([status, scheduledDate])
  @@index([inspectorId, status])
  @@index([scheduledDate])
  @@index([createdAt])
}

model VerificationFinding {
  id                String     @id @default(uuid())
  inspectionId      String
  checklistItemId   String?
  checklistLabel    String
  finding           String
  confidence        Float
  evidenceReference String?
  createdAt         DateTime   @default(now())
  inspection        Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
  @@index([createdAt])
}

model ComplianceMemoryEvent {
  id                String      @id @default(uuid())
  inspectionId      String?
  siteId            String?
  checklistItemId   String?
  checklistLabel    String?
  eventType         String
  outcome           String
  finding           String?
  confidence        Float?
  evidenceReference String?
  actorId           String?
  reason            String?
  sourceRecordId    String?
  metadata          Json?
  occurredAt        DateTime    @default(now())
  actor             User?       @relation(fields: [actorId], references: [id])
  inspection        Inspection? @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  site              Site?       @relation(fields: [siteId], references: [id])

  @@unique([eventType, sourceRecordId])
  @@index([inspectionId])
  @@index([actorId, occurredAt])
  @@index([eventType, occurredAt])
  @@index([siteId, checklistItemId, outcome, occurredAt], map: "ComplianceMemoryEvent_siteId_checklistItemId_outcome_occurredAt")
}

model InspectionImage {
  id           String     @id @default(uuid())
  inspectionId String
  imageUrl     String
  description  String?
  uploadedAt   DateTime   @default(now())
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
}

model InspectionChecklist {
  id           String     @id @default(uuid())
  inspectionId String
  itemId       String
  itemLabel    String
  status       String     @default("PENDING")
  notes        String?
  evidence     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
  @@index([inspectionId, status])
  @@index([itemId])
}

model Violation {
  id              String     @id @default(uuid())
  inspectionId    String
  description     String
  severity        String
  checklistItemId String?
  imageEvidence   String?
  status          String     @default("OPEN")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  inspection      Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
  @@index([severity])
  @@index([inspectionId, severity])
  @@index([status])
  @@index([createdAt])
}

model Report {
  id           String     @id @default(uuid())
  inspectionId String     @unique
  pdfUrl       String?
  summary      String?
  generatedAt  DateTime   @default(now())
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
}

model Review {
  id           String     @id @default(uuid())
  inspectionId String
  reviewerId   String
  approved     Boolean?
  comments     String?
  reviewedAt   DateTime   @default(now())
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  reviewer     User       @relation(fields: [reviewerId], references: [id])

  @@index([inspectionId])
  @@index([reviewerId])
  @@index([reviewerId, reviewedAt])
  @@index([approved])
}

model ReviewAction {
  id           String     @id @default(uuid())
  inspectionId String
  reviewerId   String
  action       String
  oldStatus    String
  newStatus    String
  comments     String?
  createdAt    DateTime   @default(now())
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  reviewer     User       @relation(fields: [reviewerId], references: [id])

  @@index([inspectionId, createdAt])
  @@index([reviewerId, createdAt])
}

model TrustHistory {
  id            String   @id @default(uuid())
  inspectorId   String
  score         Float
  previousScore Float?
  reasons       Json?
  createdAt     DateTime @default(now())
  inspector     User     @relation(fields: [inspectorId], references: [id], onDelete: Cascade)

  @@index([inspectorId, createdAt])
}

model OrdiAssessment {
  id           String     @id @default(uuid())
  inspectionId String
  score        Float
  riskLevel    String
  priority     String
  trend        String
  contributors Json
  createdAt    DateTime   @default(now())
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId, createdAt])
}

model ReportVersion {
  id           String     @id @default(uuid())
  inspectionId String
  versionType  String
  content      String
  authorId     String?
  createdAt    DateTime   @default(now())
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId, createdAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String
  entityId   String
  changes    Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([entityType, entityId, createdAt])
  @@index([userId, createdAt])
}

model TrustScore {
  id                 String   @id @default(uuid())
  inspectorId        String   @unique
  score              Float    @default(100)
  totalInspections   Int      @default(0)
  flaggedInspections Int      @default(0)
  lastUpdated        DateTime @default(now())
  inspector          User     @relation(fields: [inspectorId], references: [id], onDelete: Cascade)

  @@index([inspectorId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  actionUrl String?
  read      Boolean  @default(false)
  metadata  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
  @@index([type])
  @@index([createdAt])
}
