# NIRIKSHA Inspection Workflow - Frontend Environment Variables
# Copy this file to .env and fill in the actual values

# ============================================================================
# API Configuration
# ============================================================================
VITE_API_URL=http://localhost:8000/api/v1

# ============================================================================
# Application Configuration
# ============================================================================
VITE_APP_NAME=NIRIKSHA Inspection Workflow
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# ============================================================================
# Feature Flags
# ============================================================================
VITE_ENABLE_OFFLINE_SUPPORT=true
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_NOTIFICATIONS=true

# ============================================================================
# File Upload Configuration
# ============================================================================
VITE_MAX_FILE_SIZE_MB=100
VITE_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
VITE_ALLOWED_DOCUMENT_TYPES=application/pdf

# ============================================================================
# Map Configuration (for location tracking)
# ============================================================================
VITE_MAP_API_KEY=
VITE_MAP_DEFAULT_LAT=28.6139
VITE_MAP_DEFAULT_LNG=77.2090

# ============================================================================
# Analytics Configuration
# ============================================================================
VITE_ENABLE_ANALYTICS=false
VITE_ANALYTICS_ID=
